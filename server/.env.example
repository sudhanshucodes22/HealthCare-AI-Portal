# ============================================================
#  Healthcare AI Platform - Backend Environment Variables
#  Copy this file to .env and fill in the values
# ============================================================

# Server
PORT=3000
NODE_ENV=production

# ───────────────────────────────────────────────
# DATABASE (choose ONE of the two below)
# ───────────────────────────────────────────────

# Option A: PostgreSQL (recommended for production)
# Get a free PostgreSQL DB at: https://supabase.com or https://neon.tech
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Option B: SQLite (local development only – do NOT use on Vercel serverless)
# DB_PATH=./database.sqlite

# Disable SSL if your PostgreSQL provider doesn't require it (rare)
# DB_SSL=false

# ───────────────────────────────────────────────
# SECURITY
# ───────────────────────────────────────────────

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# ───────────────────────────────────────────────
# AI FEATURES
# ───────────────────────────────────────────────

# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ───────────────────────────────────────────────
# MAPS (optional – Overpass/OpenStreetMap is used if not set)
# ───────────────────────────────────────────────

# Optional: Google Maps API key for premium place data
# If NOT set, the app uses free OpenStreetMap data (Overpass API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ───────────────────────────────────────────────
# CORS – Your deployed frontend URL(s)
# ───────────────────────────────────────────────

# The exact URL where your frontend is hosted (no trailing slash)
# For multiple URLs, separate with commas (no spaces)
# Example: https://myapp.vercel.app,https://myapp.netlify.app
FRONTEND_URL=https://your-frontend-url.vercel.app
